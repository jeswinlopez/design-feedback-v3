# Supabase — client-safe values only. NEVER put the service role key here.
# Find these in your Supabase project: Settings → API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Publishable / anon key (client-safe). Prefer the modern sb_publishable_... key.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
